__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# mypy / type checking
.mypy_cache/
.dmypy.json
dmypy.json

# ruff / linters
.ruff_cache/

# Alembic – keep migrations, ignore auto-generated env artefacts
# (do NOT ignore backend/alembic/ itself)

# Uploads & local data
backend/uploads/
data/uploads/
*.pdf
*.docx

# Sentence-transformers model cache
.cache/
backend/.cache/

# SQLite dev databases
*.db
*.sqlite3

# Logs
*.log
logs/

