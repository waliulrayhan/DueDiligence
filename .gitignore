# NODE / FRONTEND
# =============================================================================

node_modules/
frontend/node_modules/

# Vite build output
frontend/dist/
frontend/.vite/

# TypeScript build info
*.tsbuildinfo
frontend/tsconfig.tsbuildinfo

# Local Vite/ESBuild cache
frontend/.cache/

